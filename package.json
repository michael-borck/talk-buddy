{
  "name": "talk-buddy-desktop",
  "version": "2.13.1",
  "description": "Talk Buddy - AI-powered conversation practice desktop app",
  "author": {
    "name": "Michael Borck",
    "email": "michael@talkbuddy.app"
  },
  "main": "src/main/index.js",
  "homepage": "./",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:3307 && electron . --dev --no-sandbox\"",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron-dev": "electron .",
    "electron:prod": "NODE_ENV=production electron .",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:3307 && electron . --dev\"",
    "electron:dev-nosandbox": "concurrently -k \"vite\" \"wait-on tcp:3307 && electron . --dev --no-sandbox\"",
    "electron:build": "npm run build && electron-builder --config electron-builder.config.js",
    "electron:dist": "npm run build && electron-builder --config electron-builder.config.js --publish=never",
    "electron:dist-all": "npm run build && electron-builder --config electron-builder.config.js -mwl --publish=never",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.316.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.8.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.5",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [
      "last 1 electron version"
    ],
    "development": [
      "last 1 electron version"
    ]
  }
}
